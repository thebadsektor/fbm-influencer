generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  role             String?
  banned           Boolean?
  banReason        String?
  banExpires       DateTime?
  feedbacks        Feedback[]
  discussions      Discussion[]
  comments         Comment[]
  stripeCustomerId String?

  discussionVotes   DiscussionVote[]
  discussionReports DiscussionReport[]
  commentVotes      CommentVote[]
  notifications     Notification[]
  campaigns         Campaign[]
  credentials       Credential[]

  @@unique([email])
  @@map("user")
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  description String?
  link        String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification")
}

model Discussion {
  id               String             @id @default(cuid())
  title            String
  content          String             @db.Text
  isPublic         Boolean            @default(true)
  isSeo            Boolean            @default(false)
  isLocked         Boolean            @default(false)
  lockReason       String?
  sourceFeedbackId String?
  views            Int                @default(0)
  userId           String
  user             User               @relation(fields: [userId], references: [id])
  comments         Comment[]
  votes            DiscussionVote[]
  reports          DiscussionReport[]
  discussionViews  DiscussionView[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  feedback         Feedback?

  @@map("discussion")
}

model DiscussionVote {
  id           String     @id @default(cuid())
  type         String // UPVOTE or DOWNVOTE
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@unique([userId, discussionId])
  @@map("discussion_vote")
}

model DiscussionReport {
  id           String     @id @default(cuid())
  reason       String
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)

  @@map("discussion_report")
}

model DiscussionView {
  id           String     @id @default(cuid())
  userId       String?
  ipAddress    String?
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@map("discussion_view")
}

model Comment {
  id              String        @id @default(cuid())
  content         String        @db.Text
  discussionId    String
  discussion      Discussion    @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  votes           CommentVote[]
  isHighlighted   Boolean       @default(false)
  parentCommentId String?
  parentComment   Comment?      @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         Comment[]     @relation("CommentReplies")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("comment")
}

model CommentVote {
  id        String  @id @default(cuid())
  type      String // UPVOTE or DOWNVOTE
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  commentId String
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@map("comment_vote")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

model Feedback {
  id           String          @id @default(cuid())
  email        String
  text         String          @db.Text
  source       String?
  status       String          @default("pending") // pending, replied
  userId       String?
  images       String[]        @default([])
  replies      FeedbackReply[]
  user         User?           @relation(fields: [userId], references: [id])
  discussionId String?         @unique
  discussion   Discussion?     @relation(fields: [discussionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("feedback")
}

model FeedbackReply {
  id         String   @id @default(cuid())
  feedbackId String
  text       String
  images     String[] @default([])
  createdAt  DateTime @default(now())
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@map("feedback_reply")
}

model FeedbackNotificationEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("feedback_notification_email")
}

model Subscription {
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  id                   String    @id @default(cuid())
  plan                 String
  referenceId          String
  stripeCustomerId     String?
  stripeSubscriptionId String?
  status               String
  periodStart          DateTime?
  periodEnd            DateTime?
  cancelAtPeriodEnd    Boolean?
  cancelAt             DateTime?
  canceledAt           DateTime?
  endedAt              DateTime?
  seats                Int?
  trialStart           DateTime?
  trialEnd             DateTime?

  @@map("subscription")
}

// ── Influencer Scouting Models ─────────────────────────

model Campaign {
  id                  String     @id @default(cuid())
  name                String
  status              String     @default("draft")
  userId              String?
  user                User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  marketingGoal       String
  brandNiche          String
  targetAudienceAge   String
  targetLocation      String[]
  audienceInterests   String[]
  minFollowers        String
  minEngagementRate   Float      @default(3)
  numberOfInfluencers Int        @default(25)
  targetKeywords      Int        @default(5)
  targetHashtags      Int        @default(5)
  trendingTopics      String?
  competitorBrands    String?
  additionalKeywords  String?
  targetLeads         Int        @default(2000)
  maxIterations       Int        @default(10)
  autoRun             Boolean    @default(true)
  enrichmentBudget    Float?
  enrichAfterRounds   Int        @default(0)
  documents           Document[]
  khSets              KHSet[]
  iterations          CampaignIteration[]
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@map("campaign")
}

model Document {
  id         String   @id @default(cuid())
  campaignId String
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  filename   String
  mimeType   String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  @@map("document")
}

model DocumentAnalysisCache {
  id              String   @id @default(cuid())
  filename        String
  fileSize        Int
  analysis        String   @db.Text
  documentContent String   @db.Text
  mimeType        String
  createdAt       DateTime @default(now())

  @@unique([filename, fileSize])
  @@map("document_analysis_cache")
}

model KHSet {
  id             String    @id @default(cuid())
  campaignId     String
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  keywords       String[]
  hashtags       String[]
  locked         Boolean   @default(false)
  status         String    @default("draft")
  platform         String?
  n8nExecutionId   String?
  results          Result[]
  parentSetId      String?
  iterationNumber  Int       @default(1)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Stats — updated by n8n scheduled sync workflow
  totalScraped   Int       @default(0)
  qualified      Int       @default(0)
  disqualified   Int       @default(0)
  missingEmail   Int       @default(0)
  enriched       Int       @default(0)
  leadPoolUrl    String?
  extraStats     Json      @default("{}")   // overflow stats e.g. { "enriched2": 15 }
  lastSyncedAt   DateTime?

  @@map("kh_set")
}

model Result {
  id               String   @id @default(cuid())
  khSetId          String
  khSet            KHSet    @relation(fields: [khSetId], references: [id], onDelete: Cascade)
  platform         String
  platformId       String?
  creatorName      String?
  creatorHandle    String?
  profileUrl       String?
  email            String?
  emailSource      String?
  emailType        String?
  confidence       String?
  followers        String?
  engagementRate   String?
  bio              String?  @db.Text
  rawText          String?  @db.Text
  hashtags         String?  @db.Text
  crawlTargets     String?  @db.Text
  verified         Boolean?
  avatar           String?
  videoCount       Int?
  totalViews       Int?
  avgViews         Int?
  avgLikes         Int?
  topVideoViews    Int?
  scrapeHits       Int?
  recentActivity   String?
  rawData          Json?
  affinityProfile  Json?
  campaignFitScore Float?
  enrichmentRuns   EnrichmentRun[]
  createdAt        DateTime @default(now())

  @@map("result")
}

model EnrichmentRun {
  id          String    @id @default(cuid())
  resultId    String
  result      Result    @relation(fields: [resultId], references: [id], onDelete: Cascade)
  workflow    String
  status      String    @default("pending")
  input       Json?
  output      Json?
  error       String?
  cost        Float?
  executionId String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([resultId, workflow])
  @@index([workflow, status])
  @@map("enrichment_run")
}

model CampaignIteration {
  id                      String   @id @default(cuid())
  campaignId              String
  campaign                Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  iterationNumber         Int
  khSetId                 String?

  // What was tried
  keywordsUsed            String[]
  hashtagsUsed            String[]
  platformUsed            String?

  // What happened
  resultsCount            Int      @default(0)
  profiledCount           Int      @default(0)
  skippedCount            Int      @default(0)
  avgFitScore             Float?
  fitDistribution         Json?

  // What was learned
  topPerformingKeywords   String[]
  lowPerformingKeywords   String[]
  exclusionPatterns       Json?
  contentThemeFrequency   Json?

  // AI reasoning (visible to user)
  analysisNarrative       String?  @db.Text
  strategyForNext         String?  @db.Text
  learnings               String[]

  // Cost and duration tracking
  profilingCost           Float?
  profilingDuration       Int?
  discoveryDuration       Int?
  createdAt               DateTime @default(now())

  @@unique([campaignId, iterationNumber])
  @@map("campaign_iteration")
}

model Credential {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceType    String
  provider       String
  label          String
  encryptedValue String
  iv             String
  authTag        String
  isPlatform     Boolean  @default(false)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, provider, isPlatform])
  @@map("credential")
}
